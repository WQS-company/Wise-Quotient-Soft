# Firebase Credentials Configuration
# Copy this file to .env and fill in your details

FIREBASE_API_KEY="AIzaSyYourApiKeyHere"
FIREBASE_AUTH_DOMAIN="wise-quotient-soft.firebaseapp.com"
FIREBASE_PROJECT_ID="wise-quotient-soft"
FIREBASE_STORAGE_BUCKET="wise-quotient-soft.appspot.com"
FIREBASE_MESSAGING_SENDER_ID="123456789012"
FIREBASE_APP_ID="1:123456789012:web:abcdef0123456789"
FIREBASE_MEASUREMENT_ID="G-MEASUREID123"

# FCM Server Key (Legacy Server Key from Cloud Messaging settings)
# Required for PHP server-side push dispatches via legacy cURL protocol
FIREBASE_SERVER_KEY=""
